</span></span><span><span>    </span><span class="token token" style="color: rgb(204, 123, 244);">this</span><span class="token token" style="color: rgb(211, 215, 222);">.</span><span class="token token property-access">player</span><span class="token token" style="color: rgb(211, 215, 222);">.</span><span class="token token property-access" style="color: rgb(112, 184, 255);">setBounce</span><span class="token token" style="color: rgb(211, 215, 222);">(</span><span class="token token" style="color: rgb(94, 237, 237);">0.2</span><span class="token token" style="color: rgb(211, 215, 222);">)</span><span class="token token" style="color: rgb(211, 215, 222);">;</span><span>
